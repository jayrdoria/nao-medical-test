# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ajaia-docs?retryWrites=true&w=majority&appName=ajaia-docs

# Auth.js v5 — both vars required
NEXTAUTH_SECRET=your-secret-min-32-chars
AUTH_SECRET=your-secret-min-32-chars

# App URL
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Required when running behind Docker / proxy
AUTH_TRUST_HOST=true
